# Copy this file to .env.local and set real values for your machine.
# Do NOT commit .env.local to source control.
# Do NOT put real passwords, client names, or personal data in this file.
# Real passwords must only ever exist in .env.local on your local PC.

# -------------------------------------------------------------------------
# App — single Next.js process, no separate backend
# -------------------------------------------------------------------------
APP_URL=http://localhost:3000

FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# In this scaffold the backend is the same process as the frontend.
# Both values point to the same port.
BACKEND_PORT=3000
BACKEND_URL=http://localhost:3000

NEXT_PUBLIC_API_URL=/api

NODE_ENV=development

# -------------------------------------------------------------------------
# PostgreSQL
# -------------------------------------------------------------------------
DATABASE_PROVIDER=postgresql
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=managed_service_local
DATABASE_USER=app_user
DATABASE_PASSWORD=CHANGE_ME

# Full connection URL — takes precedence over individual vars above.
DATABASE_URL=postgresql://app_user:CHANGE_ME@localhost:5432/managed_service_local

# -------------------------------------------------------------------------
# AI — disabled by default, do not enable for local lab use
# -------------------------------------------------------------------------
LLM_PROVIDER=disabled
LLM_MODEL=
OLLAMA_URL=http://localhost:11434
ALLOW_EXTERNAL_AI_CALLS=false
ALLOW_EXTERNAL_REQUESTS=false
